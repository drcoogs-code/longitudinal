	<script>
		function exportServiceDescriptionPdf() {
			const pages = Array.from(document.querySelectorAll('#pdf-root .a4-page'));
			if (!pages.length) {
				alert('No printable pages found.');
				return;
			}

			const saveViaPdfFallback = () => {
				const report = document.getElementById('pdf-root');
				if (!report || typeof window.html2pdf !== 'function') {
					alert('Printing is not available in this view. Please open in a browser tab and use Print / Save PDF.');
					return;
				}

				window.html2pdf()
					.set({
						filename: 'mygp-service-description.pdf',
						margin: [10, 10, 10, 10],
						image: { type: 'png', quality: 1 },
						html2canvas: {
							scale: 4,
							useCORS: true,
							scrollY: 0,
							backgroundColor: '#ffffff',
							windowWidth: 1400
						},
						jsPDF: {
							unit: 'mm',
							format: 'a4',
							orientation: 'portrait',
							compress: false,
							precision: 16
						},
						pagebreak: { mode: ['css'] }
					})
					.from(report)
					.save();
			};

			const styleTag = document.querySelector('style');
			const inlineStyles = styleTag ? styleTag.textContent : '';
			const pageHtml = pages.map((page) => page.outerHTML).join('');
			const printWindow = window.open('', '_blank', 'noopener,noreferrer,width=1200,height=900');

			if (!printWindow) {
				saveViaPdfFallback();
				return;
			}

			printWindow.document.open();
			printWindow.document.write(`
				<!DOCTYPE html>
				<html lang="en">
				<head>
					<meta charset="UTF-8" />
					<meta name="viewport" content="width=device-width, initial-scale=1.0" />
					<title>mygp-service-description</title>
					<link href="https://fonts.googleapis.com/css2?family=Questrial&family=Muli:wght@300;400;600;700;800&family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
					<style>
						${inlineStyles}
						html, body { margin: 0 !important; padding: 0 !important; background: #fff !important; }
						.topbar { display: none !important; }
						.report { width: 210mm !important; max-width: 210mm !important; margin: 0 auto !important; background: #fff !important; }
						@page { size: A4; margin: 10mm; }
						@media print {
							html, body { margin: 0 !important; padding: 0 !important; }
							.a4-page { width: 210mm !important; height: 297mm !important; margin: 0 !important; overflow: hidden !important; page-break-after: always !important; break-after: page !important; }
							.a4-page:last-of-type { page-break-after: auto !important; break-after: auto !important; }
						}
					</style>
				</head>
				<body>
					<main class="report" id="pdf-root-print">${pageHtml}</main>
				</body>
				</html>
			`);
			printWindow.document.close();

			const runPrint = () => {
				try {
					printWindow.focus();
					printWindow.print();
				} catch (error) {
					saveViaPdfFallback();
				}
			};

			if (printWindow.document.fonts && printWindow.document.fonts.ready) {
				printWindow.document.fonts.ready.then(() => setTimeout(runPrint, 200));
			} else {
				setTimeout(runPrint, 400);
			}
		}
	</script>
