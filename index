<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>myGP Clinic — Service Description</title>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
	<link href="https://fonts.googleapis.com/css2?family=Questrial&family=Muli:wght@300;400;600;700;800&family=Mulish:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
	<style>
		:root {
			--taupe: #aea292;
			--dark-green: #262b24;
			--beige: #e2d2be;
			--light-gray: #dadfcf;
			--muted-green: #6d897b;
			--off-white: #dadfcf;
			--white: #ffffff;
			--text-dark: #262b24;
			--text-mid: #4a4a42;
			--font-title: 'Questrial', sans-serif;
			--font-body: 'Muli', 'Mulish', sans-serif;
		}

		* { box-sizing: border-box; margin: 0; padding: 0; }
		* { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

		@page {
			size: A4;
			margin: 10mm;
		}

		body {
			font-family: var(--font-body);
			background: #fff;
			color: var(--text-dark);
			line-height: 1.6;
			padding: 0;
		}

		.topbar {
			max-width: 980px;
			margin: 0 auto 16px;
			display: flex;
			justify-content: space-between;
			align-items: center;
			gap: 12px;
			flex-wrap: wrap;
		}

		.brand {
			font-family: var(--font-title);
			font-size: 1.4rem;
			letter-spacing: -0.4px;
			color: var(--dark-green);
		}

		.brand span { color: var(--muted-green); }

		.btn {
			border: 1px solid var(--muted-green);
			border-radius: 999px;
			background: var(--muted-green);
			color: var(--white);
			font-size: 0.75rem;
			font-weight: 700;
			letter-spacing: 1.2px;
			text-transform: uppercase;
			padding: 10px 18px;
			cursor: pointer;
		}

		.btn:hover { background: var(--dark-green); border-color: var(--dark-green); }

		.report {
			width: 210mm;
			max-width: 210mm;
			margin: 0 auto;
			border: 0;
			border-radius: 0;
			overflow: hidden;
			background: #fff;
			box-shadow: none;
		}

		.a4-page {
			width: 210mm;
			height: 297mm;
			padding: 16mm 14mm;
			page-break-after: always;
			break-after: page;
			overflow: hidden;
		}

		.a4-page:last-of-type {
			page-break-after: auto;
			break-after: auto;
		}

		.section.a4-page {
			border-top: none;
			padding: 16mm 14mm;
		}

		.brand-lockup {
			display: inline-flex;
			flex-direction: column;
			line-height: 1;
		}

		.brand-lockup__main {
			font-family: var(--font-title);
			font-size: 1.45rem;
			letter-spacing: -0.6px;
			color: var(--dark-green);
		}

		.brand-lockup__main span {
			color: var(--muted-green);
		}

		.brand-lockup__sub {
			margin-top: 2px;
			font-size: 0.52rem;
			letter-spacing: 4px;
			text-transform: uppercase;
			font-weight: 800;
			color: var(--taupe);
		}

		.brand-lockup--light .brand-lockup__main,
		.brand-lockup--light .brand-lockup__sub {
			color: rgba(255, 255, 255, 0.95);
		}

		.brand-lockup--light .brand-lockup__main span {
			color: var(--muted-green);
		}

		.cover {
			background: var(--dark-green);
			color: var(--white);
			padding: 16mm 14mm;
			height: 297mm;
			display: flex;
			flex-direction: column;
		}

		.cover-kicker {
			font-size: 0.66rem;
			font-weight: 800;
			letter-spacing: 3px;
			text-transform: uppercase;
			color: var(--muted-green);
			margin-bottom: 14px;
		}

		.cover h1 {
			font-family: var(--font-title);
			font-size: 2.3rem;
			line-height: 1.12;
			margin-bottom: 12px;
		}

		.cover p {
			max-width: 70ch;
			color: rgba(255, 255, 255, 0.74);
			font-size: 0.9rem;
			line-height: 1.75;
		}

		.cover-context {
			font-size: 0.95rem;
			font-weight: 700;
			color: var(--muted-green);
			margin-top: 6px;
		}


		.cover-logo {
			display: flex;
			justify-content: flex-end;
			margin-top: -2px;
			margin-bottom: 14px;
		}

		.cover-divider {
			margin: 72px 0 56px;
			height: 1px;
			background: rgba(255, 255, 255, 0.7);
		}

		.cover-points {
			margin-top: auto;
			margin-left: 38px;
			display: grid;
			gap: 14px;
			max-width: 380px;
		}

		.cover-point {
			font-size: 0.92rem;
			color: var(--muted-green);
			font-weight: 700;
		}

		.meta-grid {
			margin-top: 22px;
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 10px;
		}

		.meta-card {
			border: 1px solid rgba(255, 255, 255, 0.14);
			background: rgba(255, 255, 255, 0.06);
			border-radius: 10px;
			padding: 12px 14px;
		}

		.meta-label {
			font-size: 0.58rem;
			letter-spacing: 2px;
			text-transform: uppercase;
			color: var(--muted-green);
			font-weight: 800;
			margin-bottom: 4px;
		}

		.meta-value {
			font-family: var(--font-title);
			font-size: 0.95rem;
		}

		.section {
			padding: 30px 36px;
			border-top: 1px solid var(--light-gray);
		}

		.section h2 {
			font-family: var(--font-title);
			color: var(--dark-green);
			font-size: 1.45rem;
			margin-bottom: 12px;
		}

		.section p {
			color: var(--text-mid);
			font-size: 0.92rem;
			line-height: 1.75;
			margin-bottom: 10px;
		}

		.intro-band {
			background: linear-gradient(135deg, rgba(109, 137, 123, 0.1) 0%, rgba(226, 210, 190, 0.35) 100%);
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			padding: 16px 18px;
			margin-top: 10px;
		}

		.intro-band p {
			margin-bottom: 0;
			font-size: 0.9rem;
		}

		.contents-table {
			width: 100%;
			border-collapse: collapse;
			margin-top: 14px;
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			overflow: hidden;
		}

		.contents-table thead {
			background: linear-gradient(135deg, rgba(109, 137, 123, 0.08) 0%, rgba(109, 137, 123, 0.12) 100%);
		}

		.contents-table th {
			text-align: left;
			padding: 14px 16px;
			font-size: 0.8rem;
			font-weight: 800;
			letter-spacing: 1.5px;
			text-transform: uppercase;
			color: var(--dark-green);
			border-bottom: 2px solid var(--light-gray);
		}

		.contents-table tbody tr {
			border-bottom: 1px solid var(--beige);
		}

		.contents-table tbody tr:last-child {
			border-bottom: none;
		}

		.contents-table td {
			padding: 12px 16px;
			vertical-align: top;
		}

		.contents-table__title {
			font-weight: 700;
			letter-spacing: 0.3px;
			width: 42%;
		}

		.contents-table__title a {
			text-decoration: none;
			color: var(--dark-green);
		}

		.contents-table__title a:hover {
			color: var(--muted-green);
		}

		.contents-table__desc {
			font-size: 0.82rem;
			color: var(--text-mid);
			line-height: 1.5;
		}

		.contents-table__title a {
			text-decoration: none;
			color: var(--dark-green);
		}

		.contents-table__title a:hover {
			color: var(--muted-green);
		}

		.lead-note {
			font-size: 1rem;
			line-height: 1.8;
			color: var(--text-mid);
		}

		.letter-box {
			margin-top: 14px;
			background: #fff;
			border: 1px solid var(--light-gray);
			border-top: 3px solid var(--muted-green);
			border-radius: 12px;
			padding: 16px;
		}

		.letter-box p {
			margin-bottom: 12px;
		}

		.quote-block {
			margin: 14px 0;
			padding: 14px 16px;
			border-left: 3px solid var(--muted-green);
			background: var(--off-white);
			border-radius: 8px;
			font-style: italic;
		}

		.kpi-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 10px;
			margin-top: 12px;
		}

		.kpi-card {
			background: var(--off-white);
			border: 1px solid var(--light-gray);
			border-radius: 10px;
			padding: 12px;
		}

		.kpi-card h3 {
			font-family: var(--font-title);
			font-size: 0.92rem;
			margin-bottom: 4px;
		}

		.kpi-card p {
			margin: 0;
			font-size: 0.82rem;
		}

		.medicine-models {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 12px;
			margin-top: 14px;
		}

		.model-card {
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			padding: 14px;
			background: #fff;
		}

		.model-card h3 {
			font-family: var(--font-title);
			font-size: 1rem;
			margin-bottom: 2px;
		}

		.model-card__tag {
			font-size: 0.72rem;
			font-weight: 700;
			letter-spacing: 0.6px;
			color: var(--muted-green);
			text-transform: uppercase;
			margin-bottom: 8px;
		}

		.model-list {
			display: grid;
			gap: 6px;
			font-size: 0.84rem;
			color: var(--text-mid);
		}

		.horsemen-list {
			margin-top: 10px;
			display: grid;
			gap: 8px;
		}

		.horseman-item {
			border: 1px solid var(--light-gray);
			border-left: 3px solid var(--muted-green);
			border-radius: 10px;
			padding: 10px 12px;
			background: #fff;
			font-size: 0.86rem;
		}

		.report-list {
			margin-top: 10px;
			display: grid;
			gap: 7px;
		}

		.report-list li {
			margin-left: 18px;
			font-size: 0.9rem;
			color: var(--text-mid);
		}

		.pillar-long {
			margin-top: 12px;
			display: grid;
			gap: 10px;
		}

		.pillar-long article {
			background: #fff;
			border: 1px solid var(--light-gray);
			border-radius: 10px;
			padding: 12px;
		}

		.pillar-long h3 {
			font-family: var(--font-title);
			font-size: 0.96rem;
			margin-bottom: 6px;
		}

		.subtle {
			font-size: 0.8rem;
			color: var(--taupe);
		}

		.offer-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 14px;
			margin-top: 14px;
		}

		.offer-card {
			background: #fff;
			border: 1px solid var(--light-gray);
			border-top: 3px solid var(--muted-green);
			border-radius: 12px;
			padding: 16px;
		}

		.offer-card h3 {
			font-family: var(--font-title);
			font-size: 1.05rem;
			color: var(--dark-green);
			margin-bottom: 4px;
		}

		.offer-tag {
			font-size: 0.7rem;
			font-weight: 700;
			letter-spacing: 1px;
			text-transform: uppercase;
			color: var(--muted-green);
			margin-bottom: 8px;
		}

		.offer-price {
			font-family: var(--font-title);
			font-size: 1.35rem;
			color: var(--dark-green);
			margin: 8px 0;
		}

		.template-note {
			font-size: 0.8rem;
			color: var(--taupe);
			margin-top: 6px;
		}

		.checklist {
			display: grid;
			gap: 7px;
			margin-top: 10px;
		}

		.checklist div {
			font-size: 0.86rem;
			color: var(--text-mid);
			padding-left: 16px;
			position: relative;
		}

		.checklist div::before {
			content: "•";
			position: absolute;
			left: 0;
			top: 0;
			color: var(--muted-green);
			font-weight: 800;
		}

		.split-detail {
			display: grid;
			grid-template-columns: 1.15fr 1fr;
			gap: 14px;
			margin-top: 12px;
		}

		.detail-panel {
			background: #fff;
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			padding: 14px;
		}

		.detail-panel h3 {
			font-family: var(--font-title);
			font-size: 0.98rem;
			color: var(--dark-green);
			margin-bottom: 8px;
		}

		.feature-band {
			margin-top: 14px;
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 8px;
		}

		.feature-pill {
			background: #fff;
			border: 1px solid var(--light-gray);
			border-radius: 10px;
			padding: 10px;
			font-size: 0.76rem;
			font-weight: 700;
			color: var(--text-mid);
			text-align: center;
		}

		.assessment-shell {
			background: #fff;
			border: 1px solid var(--light-gray);
			border-radius: 14px;
			padding: 18px;
			margin-top: 14px;
		}

		.assessment-head {
			display: grid;
			grid-template-columns: 1fr auto;
			gap: 12px;
			align-items: end;
			padding-bottom: 12px;
			border-bottom: 1px solid var(--light-gray);
		}

		.assessment-head h3 {
			font-family: var(--font-title);
			font-size: 1.55rem;
			line-height: 1.15;
			color: var(--dark-green);
		}

		.assessment-head__meta {
			text-align: right;
		}

		.assessment-head__price {
			font-family: var(--font-title);
			font-size: 1.25rem;
			color: var(--dark-green);
		}

		.assessment-head__time {
			font-size: 0.72rem;
			font-weight: 700;
			letter-spacing: 1px;
			text-transform: uppercase;
			color: var(--muted-green);
			margin-top: 2px;
		}

		.area-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 10px;
			margin-top: 14px;
		}

		.area-item {
			border: 1px solid var(--light-gray);
			border-radius: 10px;
			padding: 10px 8px;
			background: #faf9f6;
			text-align: center;
			min-height: 94px;
			display: flex;
			flex-direction: column;
			justify-content: center;
			gap: 8px;
		}

		.area-item__icon {
			width: 30px;
			height: 30px;
			border-radius: 999px;
			margin: 0 auto;
			border: 1px dashed var(--muted-green);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 0.72rem;
			font-weight: 700;
			color: var(--muted-green);
		}

		.area-item__label {
			font-size: 0.74rem;
			line-height: 1.3;
			font-weight: 700;
			color: var(--text-mid);
		}

		.detail-columns {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 12px;
			margin-top: 14px;
		}

		.detail-block {
			border: 1px solid var(--light-gray);
			border-radius: 10px;
			padding: 12px;
			background: #fff;
		}

		.detail-block h4 {
			font-family: var(--font-title);
			font-size: 0.96rem;
			margin-bottom: 8px;
			color: var(--dark-green);
		}

		.detail-block p {
			font-size: 0.84rem;
			line-height: 1.6;
			color: var(--text-mid);
			margin-bottom: 0;
		}

		.cards {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 12px;
			margin-top: 10px;
		}

		.card {
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			background: var(--off-white);
			padding: 14px;
		}

		.card h3 {
			font-family: var(--font-title);
			font-size: 0.98rem;
			margin-bottom: 6px;
			color: var(--dark-green);
		}

		.card p {
			font-size: 0.86rem;
			margin: 0;
		}

		.timeline {
			display: grid;
			gap: 8px;
			margin-top: 10px;
		}

		.timeline-step {
			border: 1px solid var(--light-gray);
			border-left: 3px solid var(--muted-green);
			border-radius: 10px;
			padding: 12px 14px;
			background: var(--white);
			font-size: 0.88rem;
			color: var(--text-mid);
		}

		.timeline-step strong {
			color: var(--dark-green);
			display: inline-block;
			min-width: 84px;
		}

		.pillars-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 12px;
			margin-top: 12px;
		}

		.pillar-card {
			border: 1px solid var(--light-gray);
			border-top: 3px solid var(--muted-green);
			border-radius: 12px;
			padding: 14px;
			background: var(--white);
		}

		.pillar-card h3 {
			font-family: var(--font-title);
			font-size: 1rem;
			color: var(--dark-green);
			margin-bottom: 6px;
		}

		.pillar-card p {
			font-size: 0.86rem;
			margin-bottom: 0;
		}

		.medicine-graphic {
			margin-top: 14px;
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			gap: 12px;
			align-items: stretch;
		}

		.medicine-graphic__block {
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			padding: 14px;
			background: var(--off-white);
		}

		.medicine-graphic__title {
			font-family: var(--font-title);
			font-size: 0.95rem;
			color: var(--dark-green);
			margin-bottom: 8px;
		}

		.medicine-graphic__list {
			display: grid;
			gap: 7px;
		}

		.medicine-graphic__pill {
			font-size: 0.74rem;
			padding: 7px 10px;
			border-radius: 999px;
			border: 1px solid var(--light-gray);
			background: #fff;
			color: var(--text-mid);
		}

		.medicine-graphic__arrow {
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			color: var(--muted-green);
			font-weight: 700;
			padding: 0 4px;
		}

		.healthspan-graphic {
			margin-top: 14px;
			border: 1px solid var(--light-gray);
			border-radius: 12px;
			padding: 14px;
			background: #fff;
		}

		.healthspan-graphic__legend {
			display: flex;
			gap: 10px;
			flex-wrap: wrap;
			margin-bottom: 12px;
		}

		.healthspan-graphic__legend-item {
			font-size: 0.7rem;
			color: var(--text-mid);
			display: inline-flex;
			align-items: center;
			gap: 6px;
		}

		.healthspan-graphic__dot {
			width: 10px;
			height: 10px;
			border-radius: 999px;
			display: inline-block;
		}

		.healthspan-graphic__dot--lifespan {
			background: var(--taupe);
		}

		.healthspan-graphic__dot--healthspan {
			background: var(--muted-green);
		}

		.healthspan-bars {
			display: grid;
			gap: 8px;
		}

		.healthspan-row {
			display: grid;
			grid-template-columns: 140px 1fr;
			gap: 10px;
			align-items: center;
		}

		.healthspan-row__label {
			font-size: 0.72rem;
			font-weight: 700;
			letter-spacing: 0.4px;
			text-transform: uppercase;
			color: var(--dark-green);
		}

		.healthspan-row__track {
			height: 18px;
			border: 1px solid var(--light-gray);
			border-radius: 999px;
			background: var(--off-white);
			position: relative;
			overflow: hidden;
		}

		.healthspan-row__lifespan,
		.healthspan-row__healthspan {
			position: absolute;
			top: 0;
			left: 0;
			height: 100%;
			border-radius: 999px;
		}

		.healthspan-row__lifespan {
			background: rgba(174, 162, 146, 0.45);
			width: var(--life, 95%);
		}

		.healthspan-row__healthspan {
			background: var(--muted-green);
			width: var(--health, 75%);
		}

